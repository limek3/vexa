# Supabase public client values
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Supabase server values. Never expose these in client code.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
DATABASE_URL=postgresql://postgres.xxx:password@xxx.pooler.supabase.com:6543/postgres

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional maps
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=

# App secrets
KEY_VAULTS_SECRET=replace_with_long_random_secret

# Telegram support reports
TELEGRAM_BOT_TOKEN=
TELEGRAM_SUPPORT_CHAT_ID=
NEXT_PUBLIC_SUPPORT_TELEGRAM_URL=https://t.me/your_username

# Telegram bot auth
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# Optional: protect /api/cron/reminders if you call it manually
CRON_SECRET=

# VK classic OAuth auth through oauth.vk.com
# Use VK developer app credentials. VK_ID_* names are kept for compatibility.
# Callback in ClickBook: https://your-domain.com/api/auth/vk/callback
VK_ID_CLIENT_ID=
VK_ID_CLIENT_SECRET=
VK_ID_REDIRECT_URI=
VK_ID_SCOPE=

# VK bot for client reminders, booking buttons, and VK chat replies
VK_BOT_GROUP_ID=
NEXT_PUBLIC_VK_BOT_SCREEN_NAME=
VK_BOT_ACCESS_TOKEN=
VK_BOT_SECRET=
VK_BOT_CONFIRMATION_CODE=

# Render deployment
# Use your temporary Render URL first, then replace with https://кликбук.рф after custom domain works.
APP_URL=https://your-service.onrender.com
NEXT_PUBLIC_APP_URL=https://your-service.onrender.com
NODE_VERSION=22.16.0
NEXT_TELEMETRY_DISABLED=1
