# Vexa local environment.
# Copy this file to .env.local and fill real values there. Do not commit .env.local.

# Supabase public client values.
# Get these in Supabase Dashboard -> Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Supabase server values. Never expose these in client code.
# Get the secret/service role key in Supabase Dashboard -> Project Settings -> API Keys.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# App secrets
KEY_VAULTS_SECRET=replace_with_long_random_secret

# Optional Telegram notification bot.
# Vexa works without this. Fill it only when you want Telegram push notifications.
# Create the bot in Telegram with @BotFather. Use /newbot, then copy the token and username.
TELEGRAM_BOT_TOKEN=
TELEGRAM_SUPPORT_CHAT_ID=
NEXT_PUBLIC_SUPPORT_TELEGRAM_URL=https://t.me/your_username

# Telegram notification/linking bot
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# Optional Telegram source scanner credentials.
# These are not required for email auth or notification bot.
# Fill later when the backend worker that scans Telegram sources is enabled.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=

# Render/Railway deployment
# Use your temporary deploy URL first, then replace after custom domain works.
APP_URL=https://your-service.up.railway.app
APP_ENV=production
NODE_VERSION=22.16.0
NEXT_TELEMETRY_DISABLED=1
