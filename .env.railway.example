# Required for auth
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Required after Railway gives you a domain
APP_URL=https://your-railway-domain.up.railway.app
NEXT_PUBLIC_APP_URL=https://your-railway-domain.up.railway.app

# Optional: Telegram delivery / bot tests
TELEGRAM_BOT_TOKEN=0000000000:telegram-bot-token
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=vexa_monitor_bot
TELEGRAM_WEBHOOK_SECRET=change-me

# Optional: support reports
TELEGRAM_SUPPORT_CHAT_ID=

# Local only. Do not enable in production unless you intentionally need a no-auth demo.
NEXT_PUBLIC_VEXA_LOCAL_MODE=0
