# Railway production values for Vexa
NODE_VERSION=22.16.0
NEXT_TELEMETRY_DISABLED=1

# IMPORTANT: first use the temporary deploy URL. After custom domain works, replace it.
APP_URL=https://your-service.up.railway.app
NEXT_PUBLIC_APP_URL=https://your-service.up.railway.app

# Supabase.
# Dashboard -> Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# App secrets
KEY_VAULTS_SECRET=replace_with_long_random_secret

# Optional Telegram notification bot.
# Vexa works without this. Fill it only when you want Telegram push notifications.
# Create/get values from Telegram @BotFather.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=replace_with_long_random_secret
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# Optional Telegram source scanner credentials.
# These are not required for email auth or notification bot.
# Fill later when the backend worker that scans Telegram sources is enabled.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
